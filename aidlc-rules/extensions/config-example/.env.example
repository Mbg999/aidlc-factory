# .env.example — environment variables for AIDLC subagents
#
# Copy to .env and fill in values.
# Never commit .env to version control.

# ── Agent execution ────────────────────────────────────────────────────────

# Maximum time (seconds) a single subagent subprocess may run.
# Default: 120
AIDLC_AGENT_TIMEOUT=120

# Enable Docker sandbox for agent execution (requires Docker desktop).
# When "1", agents run in an isolated container with read-only workspace mount.
# Default: 0 (subprocess mode)
AIDLC_USE_DOCKER=0

# Directory where agent audit logs and run artifacts are written.
# Default: <workspace-parent>/aidlc-docs/
AIDLC_DOCS_DIR=./aidlc-docs

# ── Skills ────────────────────────────────────────────────────────────────

# Override default skill search root (default: ~/.agents/skills/).
# Useful in CI when home directory is not writable.
# AIDLC_SKILLS_ROOT=/ci/shared/skills

# ── Security / audit ──────────────────────────────────────────────────────

# Set to "1" to write an audit log entry for every agent run (default: 1).
AIDLC_AUDIT_ENABLED=1

# ── MCP bridge ────────────────────────────────────────────────────────────

# Set to "1" to require explicit human approval for every MCP tool call.
# Set to "0" to auto-approve in headless/CI mode (use with caution).
AIDLC_MCP_REQUIRE_APPROVAL=1
