{
  "agents": [
    {
      "id": "midudev-autoskills",
      "name": "AutoSkills discovery agent",
      "entrypoint": "scripts/subagents/autoskills_agent.py"
    },
    {
      "id": "code-reviewer",
      "name": "Code Reviewer",
      "role": "reviewer",
      "capabilities": ["lint", "security-scan", "annotate"],
      "entrypoint": "scripts/subagents/code_reviewer.py",
      "opt_in": "extensions/subagents/code-reviewer.opt-in.md",
      "enabled_by_default": true,
      "enforce_in_phases": ["construction", "build-and-test"],
      "permissions": {
        "read": ["workspace/**"],
        "write": ["aidlc-docs/**"]
      }
    }
    ,
    {
      "id": "planner",
      "name": "Construction Planner",
      "role": "planner",
      "description": "Generate a concrete construction/build plan for the workspace (install, test, lint, build steps). Writes aidlc-docs/construction-plan.md.",
      "entrypoint": "scripts/subagents/planner.py",
      "allow_autoskills": true,
      "enabled_by_default": true,
      "enforce_in_phases": ["construction"],
      "permissions": {"read": ["workspace/**"], "write": ["aidlc-docs/**"]}
    }
    ,
    {
      "id": "builder",
      "name": "Construction Builder",
      "role": "builder",
      "description": "Suggests build commands and (optionally) runs non-destructive build checks. Writes aidlc-docs/build-report.md.",
      "entrypoint": "scripts/subagents/builder.py",
      "allow_autoskills": true,
      "enabled_by_default": true,
      "enforce_in_phases": ["construction", "build-and-test"],
      "permissions": {"read": ["workspace/**"], "write": ["aidlc-docs/**"]}
    }
    ,
    {
      "id": "construction-reviewer",
      "name": "Construction Reviewer",
      "role": "reviewer",
      "description": "Automated review during construction: style, TODOs, secrets, and optional linters (flake8/eslint). Writes aidlc-docs/construction-review.md.",
      "entrypoint": "scripts/subagents/construction_reviewer.py",
      "allow_autoskills": true,
      "enabled_by_default": true,
      "enforce_in_phases": ["construction", "build-and-test"],
      "permissions": {"read": ["workspace/**"], "write": ["aidlc-docs/**"]}
    }
  ]
}
