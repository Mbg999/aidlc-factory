{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "application-designer.input.v1",
  "title": "Application Designer — Input Contract (v1)",
  "type": "object",
  "required": ["run_id", "stage_id", "user_request", "predecessor_artifacts", "skills_required", "skill_paths_resolved"],
  "properties": {
    "run_id": { "type": "string", "pattern": "^[a-zA-Z0-9-]+$" },
    "stage_id": { "const": "application-designer" },
    "user_request": { "type": "string", "minLength": 1 },
    "predecessor_artifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "Must include requirements.md path" },
    "skills_required": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "skill_paths_resolved": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "budget": { "type": "object" },
    "gates": { "type": "array", "items": { "type": "string" }, "default": ["require_human_approval"] },
    "context_pointers": { "type": "array", "items": { "type": "string" }, "default": [] },
    "locks_required": { "type": "array", "items": { "type": "string" }, "default": [] },
    "depth_override": { "type": "string", "enum": ["minimal", "standard", "comprehensive"] },
    "model_override": { "type": "string" }
  },
  "additionalProperties": false
}
