{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "build-test-agent.output.v1",
  "title": "Build & Test Agent — Output Contract (v1)",
  "type": "object",
  "required": ["status", "unit_name", "build_status", "tests_total", "tests_passing", "tests_failing", "artifacts", "audit_entries", "skill_compliance"],
  "properties": {
    "status": { "type": "string", "enum": ["complete", "blocked", "failed", "needs_human"] },
    "unit_name": { "type": "string", "pattern": "^[a-zA-Z0-9-]+$" },
    "build_status": { "type": "string", "enum": ["success", "failed"] },
    "tests_total": { "type": "integer", "minimum": 0 },
    "tests_passing": { "type": "integer", "minimum": 0 },
    "tests_failing": { "type": "integer", "minimum": 0 },
    "coverage_pct": { "type": "number", "minimum": 0, "maximum": 100 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string", "enum": ["doc", "test", "config", "source", "handoff"] },
          "hash": { "type": "string" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "audit_entries": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "skill_compliance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill", "status", "evidence"],
        "properties": {
          "skill": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "N/A"] },
          "evidence": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "cost": { "type": "object" },
    "emitted_knowledge": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "title", "body"],
        "properties": {
          "kind": { "type": "string", "enum": ["pattern", "adr", "antipattern", "lesson", "drift_baseline_updated"] },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
          "related_artifacts": { "type": "array", "items": { "type": "string" }, "default": [] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.8 }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "conflicts_detected": { "type": "array", "default": [] },
    "locks_to_release": { "type": "array", "items": { "type": "string" }, "default": [] },
    "run_id": { "type": "string", "description": "Orchestrator run ID injected by the agent" },
    "stage_id": { "const": "build-test-agent" },
    "checks": {
      "type": "array",
      "description": "Build/test checks performed by the agent",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "SKIPPED"] },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      },
      "default": []
    }
  },
  "additionalProperties": false
}
